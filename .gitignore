# Ignore everything by default
*

# Allow config files
!CLAUDE.md
!settings.json
!.gitignore
!keybindings.json

# Allow config directories
!commands/
!commands/**
!rules/
!rules/**
!agents/
!agents/**
!skills/
!skills/**
!hooks/
!hooks/**

# Allow plugin manifest (not cache files)
!plugins/
!plugins/installed_plugins.json

# Allow linting and IDE config/ignore files
!biome.json
!eslintignore
!prettierignore
!.vscode/
!.vscode/**